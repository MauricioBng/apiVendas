{
  "info": {
    "_postman_id": "a1b2c3d4-node-api-crud",
    "name": "Node API — CRUD + testes",
    "description": "Coleção para o servidor HTTP em `src/index.js`.\n\n**Variáveis da coleção:** `baseUrl` (padrão `http://localhost:3000`) e `idCliente`, `idCidade`, etc. Ajuste os IDs após criar registros via POST.\n\n**Importar:** Postman → Import → selecione este arquivo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "idCliente", "value": "1" },
    { "key": "idCidade", "value": "1" },
    { "key": "idBairro", "value": "1" },
    { "key": "idFuncionario", "value": "1" },
    { "key": "idProduto", "value": "1" },
    { "key": "idVenda", "value": "1" },
    { "key": "idVendaItem", "value": "1" }
  ],
  "item": [
    {
      "name": "Health e testes",
      "item": [
        {
          "name": "GET / — status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "GET /teste — data/hora",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/teste"
          }
        },
        {
          "name": "GET /testebanco — Postgres",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/testebanco"
          }
        }
      ]
    },
    {
      "name": "Cidade",
      "item": [
        {
          "name": "Listar",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/cidade?limit=50&offset=0",
            "description": "Filtros opcionais: idcidade, nomecidade (adicione na URL)."
          }
        },
        {
          "name": "Incluir",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomecidade\": \"Curitiba\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/cidade"
          }
        },
        {
          "name": "Alterar",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomecidade\": \"Curitiba (atualizado)\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/cidade/{{idCidade}}"
          }
        },
        {
          "name": "Excluir",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/cidade/{{idCidade}}"
          }
        }
      ]
    },
